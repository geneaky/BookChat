<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable
            name="activity"
            type="com.example.bookchat.activities.SearchResultActivity" />
    </data>

    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".activities.SearchResultActivity">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RelativeLayout
                        android:id="@+id/Search_window"
                        android:layout_width="match_parent"
                        android:layout_height="68dp"
                        android:layout_marginTop="30dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="70dp"
                        android:background="@drawable/search_background"
                        android:paddingHorizontal="20dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/test_search_btn_Before"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginTop="17dp"
                            android:src="@drawable/search_icon_searchpage" />

                        <EditText
                            android:id="@+id/searchText_et"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="38dp"
                            android:layout_marginRight="64dp"
                            android:layout_marginTop="23dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="@font/jua_regular"
                            android:hint="책을 검색해주세요!"
                            android:inputType="text"
                            android:imeOptions="actionDone"
                            android:textColorHint="#B0B0B4"
                            android:textColor="#12121D" />

                        <ImageView
                            android:id="@+id/search_option_btn"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginRight="30dp"
                            android:layout_alignParentRight="true"
                            android:layout_marginTop="17dp"
                            android:src="@drawable/searchfilter_icon" />

                        <ImageView
                            android:id="@+id/search_window_delete_btn"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentRight="true"
                            android:onClick="@{() -> activity.clearSearchText()}"
                            android:layout_marginTop="22dp"
                            android:src="@drawable/search_window_delete" />

                    </RelativeLayout>


                    <TextView
                        android:id="@+id/search_window_cencel_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="취소"
                        android:onClick="@{() -> activity.clickCancleBtn()}"
                        android:textColor="#BBBBBB"
                        android:fontFamily="@font/jua_regular"
                        android:textSize="23sp"
                        android:layout_gravity="right"
                        android:layout_marginRight="20dp"
                        android:layout_marginTop="52dp"/>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginLeft="35dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jua_regular"
                        android:textColor="#B8B8BB"
                        android:text="검색 결과 :  "/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jua_regular"
                        android:textColor="#12121D"
                        android:text="x개"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/book_search_result_rcyView"
                    android:layout_marginTop="20dp"
                    android:layout_marginLeft="20dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/item_book_search_result"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginLeft="35dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jua_regular"
                        android:textColor="#B8B8BB"
                        android:text="관련 오픈채팅방 :  "/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jua_regular"
                        android:textColor="#12121D"
                        android:text="x개"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/chatRoom_search_result_rcyView"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</layout>
    
